# stage

import Prelude

Half : Type
MkHalf : Bool/*even*/ -> Nat -> Half

half : Nat -> Half
half n = MkHalf (ModNat n 2 == 0) (DivNat n 2)

// object code types and functions (foreign function interface)
Int : Ty
One : Int
Mul : Int -> Int -> Int
Add : Int -> Int -> Int

sqr : Int -> Int
    = \a -> (b := a; Mul b b)

(+) = Add

(^) : Int -> Nat -> Int
a ^ 1 = a
a ^ 0 = One
a ^ (half --> MkHalf True  k) =                 sqr (a ^ k)
a ^ (half --> MkHalf False k) = (c := a; Mul c (sqr (c ^ k)))

\a b -> ((a + b)^100 + b)^80
