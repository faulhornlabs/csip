# eval
# pstage

import Prelude

data builtin Polarity : Type where
  builtin Value       : Polarity
  builtin Computation : Polarity

constructor builtin PTy : Polarity -> Type    -- implicit

constructor builtin IO      : Computation
constructor builtin PBool   : Value
constructor builtin PWord   : Value
constructor builtin PString : Value
constructor builtin PArr    : Value -> PTy p -> Computation       -- implicit

constructor builtin PCode : PTy p -> Type    -- implicit

constructor builtin PLam : {v : Value} {c : PTy p} -> (v -> c) -> PArr v c
constructor builtin PApp : {v : Value} {c : PTy p} -> PArr v c -> (v -> c)

constructor builtin PLet   : {a : PTy p} {b : PTy q} -> a -> (a -> b) -> b
constructor builtin TopLet : {a : PTy p} {b : PTy q} -> a ->  a -> b  -> b

constructor builtin MkPWord   : Word   -> PWord
constructor builtin MkPString : String -> PString

constructor builtin PEqWord   : PWord   -> PWord   -> PBool
constructor builtin PEqString : PString -> PString -> PBool

-- User code

constructor Halt : IO
constructor Put :  PWord -> IO  -> IO
constructor Get : (PWord -> IO) -> IO

constructor Mul : PWord -> PWord -> PWord

sqr : PWord -> PWord
sqr a = PLet a \a -> Mul a a

power : Word -> PWord -> PWord
power 0 _ = 1
power 1 a = a
power n        a | even n = sqr (power (div n 2) a)
power (WSuc n) a          = PLet a \a -> Mul a (power n a)

test1 : PCode (PWord -> PWord)
test1 = \a -> power 10 a

sqr2 : PCode (PWord -> PWord)
sqr2 = \a -> Mul a a

power2 : PCode (PWord -> PWord) -> Word -> PWord -> PWord
power2 _ 0 _ = 1
power2 _ 1 a = a
power2 s n        a | even n = s (power2 s (div n 2) a)
power2 s (WSuc n) a          = PLet a \a -> Mul a (power2 s n a)

test2 = PLet sqr2 \s -> \a -> power2 s 10 a

test2

