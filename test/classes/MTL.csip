# elab
# eval

import Prelude

class {m : Type ~> Type} -> Functor m  where
  fmap : {m} -> Functor m => {a b} -> (a -> b) -> m a -> m b

(<$>) = fmap

class {m} -> Functor m => Applicative m  where
  pure : {m} -> Applicative m => {a} -> a -> m a
  app  : {m} -> Applicative m => {a b} -> m (a -> b) -> m a -> m b

(<*>) = app

class {m} -> Applicative m => Monad m where
  join : {m} -> Monad m => {a} -> m (m a) -> m a


(>>=) : {m a b} -> Monad m => m a -> (a -> m b) -> m b
ma >>= f = join (f <$> ma)


class {m} -> Monad m => MonadFail m where
  fail : {m} -> Monad m => {a} -> String -> m a


stateType : (Type ~> Type) -> Type

class {m} -> Monad m => MonadState m where
  state : {m} -> MonadState m => {a} -> (s = stateType m; (s -> Tuple2 a s) -> m a)

get : {m} -> MonadState m => Nat -> m (stateType m)
get 0 = state \s -> T2 s s    // TODO: without 0

put : {m} -> MonadState m => stateType m -> m Unit
put s = state \_ -> T2 TT s


class {t : (Type ~> Type) ~> Type ~> Type} -> MonadTrans t where
  lift : {t} -> MonadTrans t => {m} -> Monad m => {a} -> m a -> t m a



instance Functor Maybe where
  fmap' f Nothing  = Nothing
  fmap' f (Just a) = Just (f a)

instance Applicative Maybe where
  pure' x = Just x

  app' (Just f) (Just a) = Just (f a)
  app' _        _        = Nothing

instance Monad Maybe where
  join' (Just a) = a
  join' Nothing = Nothing

instance MonadFail Maybe where
  fail' s = Nothing




data Identity : Type ~> Type where
  MkIdentity : {a} -> a -> Identity a

instance Functor Identity where
  fmap' f (MkIdentity a) = MkIdentity (f a)

instance Applicative Identity where
  pure' x = MkIdentity x
  app' (MkIdentity f) (MkIdentity x) = MkIdentity (f x)

instance Monad Identity where
  join' (MkIdentity a) = a



instance Functor List where
  fmap' f Nil = Nil
  fmap' f (LCons x xs) = LCons (f x) (fmap' f xs)

append : {a} -> List a -> List a -> List a
append Nil xs = xs
append (LCons x xs) ys = LCons x (append xs ys)

joinList : {a} -> List (List a) -> List a
joinList Nil = Nil
joinList (LCons x xs) = append x (joinList xs)

instance Applicative List where
  pure' x = LCons x Nil

  app' fs xs = joinList (fmap' (\f -> fmap f xs) fs)

instance Monad List where
  // TODO: join' = joinList
  join' m = joinList m

instance MonadFail List where
  fail' s = Nil




data StateT : Type -> (Type ~> Type) -> Type ~> Type where
  MkStateT : {s} -> {m : Type ~> Type} -> {a} -> (s -> m (Tuple2 a s)) -> StateT s m a

instance {m s} -> Functor m => Functor (StateT s m) where
  fmap' f (MkStateT g) = MkStateT \x -> fmap (first f) (g x)


stateType (StateT s m) = s

instance {m s} -> Monad m => MonadState (StateT s m) where
  state' f = MkStateT \s -> pure (f s)


fmap'

